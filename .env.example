# ============================================================
# Outbound.AI - Environment Variable Template
# ============================================================
# Copy to `.env` and fill in.

NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000

# --- Required in every environment ---
DATABASE_URL=postgresql://postgres:root@localhost:5432/outbound_ai
REDIS_URL=redis://localhost:6379

# --- Required in every environment (server refuses to boot if unset) ---
# JWT_SECRET: signs session JWTs. Min 32 chars of entropy.
# ENCRYPTION_KEY: derived via PBKDF2 to AES-256 key. Min 24 chars.
JWT_SECRET=
ENCRYPTION_KEY=
# Optional but recommended in production: independent secrets for other purposes.
# Each falls back to JWT_SECRET if unset (backward compatible).
TRACKING_HMAC_SECRET=
OAUTH_STATE_SECRET=
# Rotation tag persisted with every ciphertext. Bump when rotating ENCRYPTION_KEY.
ENCRYPTION_KEY_ID=v1

# --- CAN-SPAM (REQUIRED in production; boot fails without them) ---
# The company name + physical mailing address appended to every outbound email.
# CAN-SPAM §7704(a)(5) requires a valid postal address in every commercial email.
SENDER_COMPANY_NAME=
SENDER_POSTAL_ADDRESS=

# --- Logging ---
# One of: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# --- AI provider selection ---
# Options: groq (default) | gemini
AI_PROVIDER=groq

# --- Required for the selected provider (endpoints return 503 if missing) ---
GROQ_API_KEY=
GEMINI_API_KEY=

# --- Optional: billing ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_FREE_ID=
STRIPE_PRICE_GROWTH_ID=
STRIPE_PRICE_ENTERPRISE_ID=

# --- Optional: Gmail / Outlook mailbox sync ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# --- Required for Lead Discovery pipeline (Places → Firecrawl → SES) ---
GOOGLE_PLACES_API_KEY=
FIRECRAWL_API_KEY=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
# Verified sender identity in your SES account (must be verified in SES console
# while your account is in sandbox mode)
SES_FROM_EMAIL=
# Optional Amazon SES Configuration Set name (for event publishing to SNS/CloudWatch)
SES_CONFIGURATION_SET=

# Public URL used in outbound-email tracking pixels and unsubscribe links.
# Falls back to APP_URL if unset. Must be reachable by the internet in prod.
PUBLIC_BASE_URL=

# ============================================================
# Docker Compose (production deployment) — see docker-compose.yml
# ============================================================
# Postgres creds for the containerized DB. The backend auto-builds a
# DATABASE_URL against these unless you pin DATABASE_URL above.
POSTGRES_DB=outbound_ai
POSTGRES_USER=outbound
POSTGRES_PASSWORD=

# Reverse-proxy host + ports.
NGINX_SERVER_NAME=your-domain.example.com
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# Optional TLS via `docker compose --profile tls run --rm certbot`.
CERTBOT_EMAIL=you@your-domain.example.com

# Worker concurrency knobs (safe defaults if unset).
EMAIL_WORKER_CONCURRENCY=3
SEQUENCE_ADVANCE_CONCURRENCY=3
SEQUENCE_TICK_INTERVAL_MS=60000
MAILBOX_POLL_INTERVAL_MS=300000

# Optional S3 bucket for scripts/backup-db.sh remote upload.
BACKUP_S3_BUCKET=
