# =========================================================================
# Outbound.AI - Enterprise Cold Outreach Platform Configuration Template
# =========================================================================

# 1. CORE AI ORCHESTRATION (Gemini SDK)
# Required for Lead Hunting, Dynamic Copywriting, Sentiment Triage, & Spam Auditing.
# In production, this must be a valid key; the application will fail-fast and throw an error if missing.
GEMINI_API_KEY=""

# 2. NETWORKING & SYSTEM HOSTING
# Automatically injected by AI Studio at runtime using the assigned Cloud Run URL.
APP_URL="http://localhost:3000"

# 3. DURABLE DATABASE LAYER (PostgreSQL)
# Connection string for production-grade relational database persistence.
# Strictly required in production; the system will fail-fast and throw if empty or unreachable.
DATABASE_URL=""

# 4. MEMORY CACHING & QUEUE STORAGE (Redis)
# URL to connect to an active Redis cluster.
# Strictly required in production; the system will fail-fast and throw if empty or unreachable.
REDIS_URL=""

# 5. ENTERPRISE BILLING ENGINE (Stripe)
# Secret API Key to connect with the real Stripe Billing Dashboard.
# Strictly required in production; mock checkout sandbox is disabled.
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Stripe Plan Price IDs (Optional - if left empty, the system creates them on-the-fly)
STRIPE_PRICE_FREE_ID=""
STRIPE_PRICE_GROWTH_ID=""
STRIPE_PRICE_ENTERPRISE_ID=""

# 6. EXTERNAL GMAIL & OUTLOOK SYNC ENGINE (OAuth)
# Credentials used to register and authorize synced third-party user mailboxes.
# Strictly required in production; sandbox authorization flow simulator is disabled.
GOOGLE_CLIENT_ID=""
MICROSOFT_CLIENT_ID=""
